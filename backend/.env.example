# ─── ImperiumAI backend env ────────────────────────────────────────────────────
# Copy to `.env` and fill in any keys you have. Empty = simulation mode.

# App
DEBUG=false
HOST=0.0.0.0
PORT=8000
RELOAD=false

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of full origins (with scheme).
# In production set this to your frontend's URL, e.g.:
#   ALLOWED_ORIGINS=https://imperium-ai-frontend.onrender.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional regex for preview/wildcard origins:
#   ALLOWED_ORIGIN_REGEX=^https://imperium-ai-frontend(-[a-z0-9]+)?\.onrender\.com$
ALLOWED_ORIGIN_REGEX=

# LLM providers (all optional — auto-detected; falls back to simulation)
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ─── Database ────────────────────────────────────────────────────────────────
# Two ways to configure storage:
#
#   1) DATABASE_URL — full SQLAlchemy URL. Use this for any server backend
#      (production / staging). Format:
#        postgresql+psycopg://USER:PASS@HOST:5432/DBNAME
#      The bare `postgres://` / `postgresql://` prefixes used by Railway /
#      Heroku / Supabase are accepted too — the app rewrites them to the
#      explicit driver form internally.
#
#   2) DB_PATH — local SQLite file. Used as a fallback when DATABASE_URL is
#      empty (so the app keeps working out of the box for dev).
#
# Examples:
#   DATABASE_URL=postgresql+psycopg://imperiumai:secret@localhost:5432/imperiumai
#   DATABASE_URL=postgres://user:pass@db.example.com:5432/imperiumai
DATABASE_URL=
DB_PATH=data/attack_memory.db

# Battle tuning
MAX_ROUNDS=10
RISK_WIN_THRESHOLD=95
CONSECUTIVE_SUCCESS_WIN=3
CONSECUTIVE_BLOCK_WIN=4
ROUND_DELAY_S=1.0
